      "source": [
        "#test\n",
        "B, T = 4, 8 # 設定批次(Batch)為 4，上下文長度(Time)為 8\n",
        "X_batch, Y_batch = get_batch('train', B, T)\n",
        "\n",
        "print(f\"\\n--- 測試 get_batch ---\")\n",
        "print(f\"X 形狀(Shape): {X_batch.shape}\")\n",
        "print(f\"Y 形狀(Shape): {Y_batch.shape}\")\n",
        "print(f\"\\n第一筆輸入 X[0]: {X_batch[0]}\")\n",
